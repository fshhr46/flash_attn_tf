common --enable_bzlmod=false
common --enable_workspace=true
build --action_env TF_HEADER_DIR="/home/hhuang2/.local/lib/python3.10/site-packages/tensorflow/include"
build --action_env TF_SHARED_LIBRARY_DIR="/home/hhuang2/.local/lib/python3.10/site-packages/tensorflow"
build --action_env TF_SHARED_LIBRARY_NAME="libtensorflow_framework.so.2"
build --action_env TF_CXX11_ABI_FLAG="1"
build --action_env TF_CXX_STANDARD="c++17"
build --action_env TF_VERSION_INTEGER="2162"
build --action_env FOR_TF_SERVING="0"
build --spawn_strategy=standalone
build --strategy=Genrule=standalone
build -c opt
build --copt=-mavx
